# ==========================================
# Nexu-Core - Variables de Entorno
# ==========================================
# Copiar este archivo a .env y completar los valores

# ==========================================
# BASE DE DATOS
# ==========================================
DATABASE_URL="file:./dev.db"

# ==========================================
# API
# ==========================================
PORT=3001

# ==========================================
# STRIPE (Pagos con tarjeta)
# ==========================================
# Obtener de: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ==========================================
# MERCADO PAGO (Latinoamérica)
# ==========================================
# Obtener de: https://www.mercadopago.com/developers/panel/credentials
MERCADOPAGO_ACCESS_TOKEN=your_access_token_here

# ==========================================
# WOMPI (Colombia)
# ==========================================
# Obtener de: https://dashboard.wompi.co/developers/keys
WOMPI_PRIVATE_KEY=your_private_key_here
WOMPI_EVENT_SECRET=your_event_secret_here
WOMPI_PRESENCE_ID=your_presence_id_here

# ==========================================
# PLACETOPAY (Colombia)
# ==========================================
# Obtener de: https://dashboard.placetopay.com
PLACETOPAY_LOGIN=your_login_here
PLACETOPAY_TRANKEY=your_trankey_here
PLACETOPAY_URL=https://test.placetopay.com

# ==========================================
# PAYU (Latinoamérica)
# ==========================================
# Obtener de: https://merchant.payulatam.com
PAYU_MERCHANT_ID=your_merchant_id
PAYU_ACCOUNT_ID=your_account_id
PAYU_API_KEY=your_api_key_here
PAYU_URL=https://sandbox.gateway.payulatam.com

# ==========================================
# WEB (Next.js)
# ==========================================
# URL de la API
NEXT_PUBLIC_API_URL=http://localhost:3001
